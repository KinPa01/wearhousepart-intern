<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================ -->
    <!-- Category Tree View - Enhanced                -->
    <!-- ============================================ -->
    <record id="spare_category_view_tree" model="ir.ui.view">
        <field name="name">spare.category.tree</field>
        <field name="model">spare.category</field>
        <field name="arch" type="xml">
            <tree string="หมวดหมู่อะไหล่" decoration-bf="part_count > 0"
                  decoration-info="part_count > 20"
                  decoration-success="part_count > 0 and part_count &lt;= 20">
                <field name="name" string="📁 หมวดหมู่"/>
                <field name="parent_id" string="📂 หมวดหมู่หลัก"/>
                <field name="part_count" string="🔧 จำนวนอะไหล่"/>
                <field name="active" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- Category Form View - Enhanced                -->
    <!-- ============================================ -->
    <record id="spare_category_view_form" model="ir.ui.view">
        <field name="name">spare.category.form</field>
        <field name="model">spare.category</field>
        <field name="arch" type="xml">
            <form string="หมวดหมู่อะไหล่">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" 
                                name="action_view_parts" icon="fa-wrench"
                                invisible="part_count == 0">
                            <field string="อะไหล่" name="part_count" widget="statinfo"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="ชื่อหมวดหมู่..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="📋 ข้อมูลหมวดหมู่">
                            <field name="parent_id"/>
                            <field name="icon"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="📂 หมวดหมู่ย่อย" invisible="not child_ids">
                            <field name="child_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="part_count"/>
                                </tree>
                            </field>
                        </page>
                        <page string="📝 หมายเหตุ">
                            <field name="note" placeholder="หมายเหตุเพิ่มเติม..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- Category Kanban View - Colorful Premium      -->
    <!-- ============================================ -->
    <record id="spare_category_view_kanban" model="ir.ui.view">
        <field name="name">spare.category.kanban</field>
        <field name="model">spare.category</field>
        <field name="arch" type="xml">
            <kanban class="wp_category_kanban">
                <field name="name"/>
                <field name="part_count"/>
                <field name="color"/>
                <field name="icon"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_color_#{kanban_getcolor(record.color.raw_value)} oe_kanban_card oe_kanban_global_click" style="border-radius:12px;overflow:hidden;">
                            <div class="oe_kanban_content" style="padding:16px;">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title" style="font-size:15px;">
                                            <i t-attf-class="fa #{record.icon.raw_value || 'fa-folder'} me-2" style="font-size:18px;"/>
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom mt-3">
                                    <div class="oe_kanban_bottom_left">
                                        <t t-if="record.part_count.raw_value > 0">
                                            <span style="background:linear-gradient(135deg,#4f46e5,#7c3aed);color:white;padding:4px 14px;border-radius:20px;font-size:12px;font-weight:700;box-shadow:0 2px 8px rgba(79,70,229,0.3);">
                                                <i class="fa fa-wrench me-1"/> <field name="part_count"/> อะไหล่
                                            </span>
                                        </t>
                                        <t t-else="">
                                            <span style="background:#f1f5f9;color:#94a3b8;padding:4px 14px;border-radius:20px;font-size:12px;font-weight:600;">
                                                <i class="fa fa-inbox me-1"/> ยังไม่มีอะไหล่
                                            </span>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- Category Search View                         -->
    <!-- ============================================ -->
    <record id="spare_category_view_search" model="ir.ui.view">
        <field name="name">spare.category.search</field>
        <field name="model">spare.category</field>
        <field name="arch" type="xml">
            <search string="ค้นหาหมวดหมู่">
                <field name="name"/>
                <field name="parent_id"/>
                <filter string="🔧 มีอะไหล่" name="has_parts" 
                        domain="[('part_count', '>', 0)]"/>
                <separator/>
                <filter string="📦 Archived" name="inactive" 
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="จัดกลุ่มตาม">
                    <filter string="📂 หมวดหมู่หลัก" name="group_parent" 
                            context="{'group_by': 'parent_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- Category Action                              -->
    <!-- ============================================ -->
    <record id="spare_category_action" model="ir.actions.act_window">
        <field name="name">หมวดหมู่อะไหล่</field>
        <field name="res_model">spare.category</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="spare_category_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                สร้างหมวดหมู่อะไหล่ใหม่
            </p>
            <p>
                จัดการหมวดหมู่สำหรับชิ้นส่วนอะไหล่มอเตอร์ไซค์
            </p>
        </field>
    </record>

</odoo>
