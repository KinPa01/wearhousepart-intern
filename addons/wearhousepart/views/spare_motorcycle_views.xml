<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kanban View - Premium Design -->
    <record id="spare_motorcycle_view_kanban" model="ir.ui.view">
        <field name="name">spare.motorcycle.kanban</field>
        <field name="model">spare.motorcycle</field>
        <field name="arch" type="xml">
            <kanban string="รุ่นมอเตอร์ไซค์" class="wp_moto_kanban">
                <field name="id"/>
                <field name="name"/>
                <field name="image_1920"/>
                <field name="model_type"/>
                <field name="engine_cc"/>
                <field name="production_year"/>
                <field name="production_status"/>
                <field name="part_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click wp_moto_card">
                            <div class="wp_moto_img_wrap">
                                <img t-att-src="kanban_image('spare.motorcycle', 'image_1920', record.id.raw_value)"
                                     t-att-alt="record.name.value"/>
                            </div>
                            <div class="wp_moto_details">
                                <div class="wp_moto_name">
                                    <field name="name"/>
                                </div>
                                <div class="wp_moto_specs">
                                    <span class="wp_cc_badge">
                                        <i class="fa fa-tachometer me-1"/><field name="engine_cc"/>cc
                                    </span>
                                    <t t-if="record.production_status.raw_value == 'current'">
                                        <span class="wp_badge_current">
                                            <i class="fa fa-check-circle me-1"/>ผลิตอยู่
                                        </span>
                                    </t>
                                    <t t-if="record.production_status.raw_value == 'discontinued'">
                                        <span class="wp_badge_discontinued">
                                            <i class="fa fa-times-circle me-1"/>ยุติการผลิต
                                        </span>
                                    </t>
                                    <t t-if="record.production_status.raw_value == 'discontinued_thai'">
                                        <span class="wp_badge_discontinued_thai">
                                            <i class="fa fa-exclamation-circle me-1"/>ยุติ (ไทย)
                                        </span>
                                    </t>
                                </div>
                                <div class="wp_moto_meta">
                                    <i class="fa fa-calendar"/> รุ่นปี <field name="production_year"/>
                                </div>
                                <div class="wp_moto_meta mt-1">
                                    <i class="fa fa-motorcycle"/> <field name="model_type"/>
                                </div>
                                <div t-if="record.part_count.raw_value > 0" class="mt-1">
                                    <span class="wp_parts_count">
                                        <i class="fa fa-wrench"/> <field name="part_count"/> อะไหล่
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Tree View - Enhanced with colors -->
    <record id="spare_motorcycle_view_tree" model="ir.ui.view">
        <field name="name">spare.motorcycle.tree</field>
        <field name="model">spare.motorcycle</field>
        <field name="arch" type="xml">
            <tree string="รุ่นมอเตอร์ไซค์"
                  decoration-success="production_status == 'current'"
                  decoration-danger="production_status == 'discontinued'"
                  decoration-warning="production_status == 'discontinued_thai'">
                <field name="name" string="🏍️ รุ่นรถ"/>
                <field name="model_type" widget="badge"
                       decoration-info="True"/>
                <field name="engine_cc" string="⚡ เครื่อง (cc)"/>
                <field name="transmission"/>
                <field name="msrp_price" widget="monetary" string="💰 ราคา MSRP"/>
                <field name="production_year" string="📅 ยุคการผลิต"/>
                <field name="production_status" widget="badge"
                       decoration-success="production_status == 'current'"
                       decoration-danger="production_status == 'discontinued'"
                       decoration-warning="production_status == 'discontinued_thai'"/>
                <field name="part_count" string="🔧 อะไหล่"/>
            </tree>
        </field>
    </record>

    <!-- Form View - Premium -->
    <record id="spare_motorcycle_view_form" model="ir.ui.view">
        <field name="name">spare.motorcycle.form</field>
        <field name="model">spare.motorcycle</field>
        <field name="arch" type="xml">
            <form string="รุ่นมอเตอร์ไซค์">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_parts" icon="fa-wrench"
                                invisible="part_count == 0">
                            <field string="อะไหล่" name="part_count" widget="statinfo"/>
                        </button>
                    </div>
                    <field name="image_1920" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image_1920'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="ชื่อรุ่นรถ..."/></h1>
                    </div>
                    <group>
                        <group string="🏍️ ข้อมูลรถ">
                            <field name="model_type" widget="radio"/>
                            <field name="engine_cc"/>
                            <field name="transmission"/>
                        </group>
                        <group string="📋 ข้อมูลการผลิต">
                            <field name="msrp_price"/>
                            <field name="production_year"/>
                            <field name="production_status" widget="radio"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="🔧 อะไหล่ที่ใช้ได้">
                            <field name="part_ids">
                                <tree decoration-danger="stock_status == 'out_of_stock'"
                                      decoration-warning="stock_status == 'low_stock'"
                                      decoration-success="stock_status == 'in_stock'">
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="category_id"/>
                                    <field name="price"/>
                                    <field name="qty_on_hand"/>
                                    <field name="stock_status" widget="badge"
                                           decoration-danger="stock_status == 'out_of_stock'"
                                           decoration-warning="stock_status == 'low_stock'"
                                           decoration-success="stock_status == 'in_stock'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="spare_motorcycle_view_search" model="ir.ui.view">
        <field name="name">spare.motorcycle.search</field>
        <field name="model">spare.motorcycle</field>
        <field name="arch" type="xml">
            <search string="ค้นหารุ่นรถ">
                <field name="name"/>
                <field name="model_type"/>
                <filter string="🟢 ผลิตอยู่" name="current" domain="[('production_status', '=', 'current')]"/>
                <filter string="🔴 ยุติการผลิต" name="discontinued" domain="[('production_status', '=', 'discontinued')]"/>
                <filter string="🟠 ยุติ (ไทย)" name="discontinued_thai" domain="[('production_status', '=', 'discontinued_thai')]"/>
                <group expand="0" string="จัดกลุ่มตาม">
                    <filter string="ประเภท" name="group_type" context="{'group_by': 'model_type'}"/>
                    <filter string="สถานะ" name="group_status" context="{'group_by': 'production_status'}"/>
                    <filter string="ขนาดเครื่อง" name="group_cc" context="{'group_by': 'engine_cc'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action - kanban first -->
    <record id="spare_motorcycle_action" model="ir.actions.act_window">
        <field name="name">รุ่นมอเตอร์ไซค์</field>
        <field name="res_model">spare.motorcycle</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="spare_motorcycle_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">เพิ่มรุ่นมอเตอร์ไซค์ใหม่</p>
            <p>จัดการข้อมูลรุ่นมอเตอร์ไซค์และอะไหล่ที่เกี่ยวข้อง</p>
        </field>
    </record>
</odoo>
