<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================ -->
    <!-- Location Tree View -->
    <!-- ============================================ -->
    <record id="spare_location_view_tree" model="ir.ui.view">
        <field name="name">spare.location.tree</field>
        <field name="model">spare.location</field>
        <field name="arch" type="xml">
            <tree>
                <field name="complete_code"/>
                <field name="name"/>
                <field name="warehouse_id"/>
                <field name="location_type" widget="badge"
                       decoration-info="location_type == 'zone'"
                       decoration-success="location_type in ('shelf','bin')"
                       decoration-warning="location_type == 'receiving'"
                       decoration-danger="location_type == 'shipping'"/>
                <field name="category_id" optional="show"/>
                <field name="part_count"/>
                <field name="capacity" optional="hide"/>
                <field name="barcode" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- Location Form View -->
    <!-- ============================================ -->
    <record id="spare_location_view_form" model="ir.ui.view">
        <field name="name">spare.location.form</field>
        <field name="model">spare.location</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_parts" type="object"
                                class="oe_stat_button" icon="fa-wrench">
                            <field name="part_count" widget="statinfo"
                                   string="อะไหล่"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="complete_code"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="warehouse_id"/>
                            <field name="parent_id"/>
                        </group>
                        <group>
                            <field name="location_type"/>
                            <field name="category_id"/>
                            <field name="capacity"/>
                            <field name="barcode"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                    <notebook>
                        <page string="ตำแหน่งย่อย" name="children">
                            <field name="child_ids">
                                <tree>
                                    <field name="complete_code"/>
                                    <field name="name"/>
                                    <field name="location_type"/>
                                    <field name="category_id"/>
                                    <field name="part_count"/>
                                </tree>
                            </field>
                        </page>
                        <page string="อะไหล่ที่จัดเก็บ" name="parts">
                            <field name="part_ids">
                                <tree>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="category_id"/>
                                    <field name="qty_on_hand"/>
                                    <field name="stock_status" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- Location Search View -->
    <!-- ============================================ -->
    <record id="spare_location_view_search" model="ir.ui.view">
        <field name="name">spare.location.search</field>
        <field name="model">spare.location</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="complete_code"/>
                <field name="warehouse_id"/>
                <field name="category_id"/>
                <filter string="โซน" name="zone"
                        domain="[('location_type','=','zone')]"/>
                <filter string="ชั้นวาง" name="shelf"
                        domain="[('location_type','=','shelf')]"/>
                <filter string="จุดรับของ" name="receiving"
                        domain="[('location_type','=','receiving')]"/>
                <group expand="0" string="จัดกลุ่มตาม">
                    <filter string="คลัง" name="group_warehouse"
                            context="{'group_by': 'warehouse_id'}"/>
                    <filter string="ประเภท" name="group_type"
                            context="{'group_by': 'location_type'}"/>
                    <filter string="หมวดหมู่" name="group_category"
                            context="{'group_by': 'category_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- Location Action -->
    <!-- ============================================ -->
    <record id="spare_location_action" model="ir.actions.act_window">
        <field name="name">ตำแหน่งจัดเก็บ</field>
        <field name="res_model">spare.location</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                สร้างตำแหน่งจัดเก็บแรกของคุณ
            </p>
        </field>
    </record>
</odoo>
