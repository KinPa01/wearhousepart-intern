<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================ -->
    <!-- Main Menu                                    -->
    <!-- ============================================ -->
    <menuitem id="spare_menu_root"
              name="🏭 คลังอะไหล่"
              web_icon="wearhousepart,static/description/icon.png"
              sequence="1"/>

    <!-- ============================================ -->
    <!-- Sub Menus                                    -->
    <!-- ============================================ -->
    
    <!-- ภาพรวม -->
    <menuitem id="spare_menu_dashboard"
              name="📊 ภาพรวม"
              parent="spare_menu_root"
              action="spare_dashboard_action"
              sequence="1"/>

    <!-- อะไหล่ -->
    <menuitem id="spare_menu_parts"
              name="📦 อะไหล่"
              parent="spare_menu_root"
              sequence="10"/>

    <menuitem id="spare_menu_part_list"
              name="📋 รายการอะไหล่"
              parent="spare_menu_parts"
              action="spare_part_action"
              sequence="1"/>

    <menuitem id="spare_menu_part_low_stock"
              name="⚠️ อะไหล่สต็อกต่ำ"
              parent="spare_menu_parts"
              action="spare_part_low_stock_action"
              sequence="2"/>

    <menuitem id="spare_menu_part_out_of_stock"
              name="🔴 อะไหล่หมดสต็อก"
              parent="spare_menu_parts"
              action="spare_part_out_of_stock_action"
              sequence="3"/>

    <!-- จัดซื้อ (PO) -->
    <menuitem id="spare_menu_purchase"
              name="🛒 จัดซื้อ"
              parent="spare_menu_root"
              sequence="15"/>

    <menuitem id="spare_menu_purchase_order"
              name="📋 ใบสั่งซื้อ (PO)"
              parent="spare_menu_purchase"
              action="spare_purchase_order_action"
              sequence="1"/>

    <!-- เบิกอะไหล่ -->
    <menuitem id="spare_menu_request"
              name="📝 เบิกอะไหล่"
              parent="spare_menu_root"
              sequence="18"/>

    <menuitem id="spare_menu_request_list"
              name="📋 ใบขอเบิก"
              parent="spare_menu_request"
              action="spare_request_action"
              sequence="1"/>

    <!-- ประวัติสต็อก (Log) -->
    <menuitem id="spare_menu_stock_log"
              name="📜 ประวัติสต็อก"
              parent="spare_menu_root"
              action="spare_stock_move_action"
              sequence="20"/>

    <!-- ตั้งค่า -->
    <menuitem id="spare_menu_config"
              name="⚙️ ตั้งค่า"
              parent="spare_menu_root"
              sequence="90"/>

    <menuitem id="spare_menu_category"
              name="📁 หมวดหมู่อะไหล่"
              parent="spare_menu_config"
              action="spare_category_action"
              sequence="1"/>

    <menuitem id="spare_menu_motorcycle"
              name="🏍️ รุ่นมอเตอร์ไซค์"
              parent="spare_menu_config"
              action="spare_motorcycle_action"
              sequence="2"/>

    <menuitem id="spare_menu_warehouse"
              name="🏭 คลังสินค้า"
              parent="spare_menu_config"
              action="spare_warehouse_action"
              sequence="3"/>

    <menuitem id="spare_menu_location"
              name="📍 ตำแหน่งจัดเก็บ"
              parent="spare_menu_config"
              action="spare_location_action"
              sequence="4"/>

</odoo>
