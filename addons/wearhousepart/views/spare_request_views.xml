<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================ -->
    <!-- Request Tree View -->
    <!-- ============================================ -->
    <record id="spare_request_view_tree" model="ir.ui.view">
        <field name="name">spare.request.tree</field>
        <field name="model">spare.request</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'draft'"
                  decoration-warning="state == 'submitted'"
                  decoration-success="state == 'done'"
                  decoration-danger="state == 'rejected'"
                  decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="requester_id"
                       widget="many2one_avatar_user"/>
                <field name="department" optional="show"/>
                <field name="date_request"/>
                <field name="line_count"/>
                <field name="reason" optional="hide"/>
                <field name="approver_id"
                       widget="many2one_avatar_user"
                       optional="show"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-success="state in ('approved','done')"
                       decoration-danger="state == 'rejected'"
                       decoration-primary="state == 'picking'"
                       decoration-muted="state == 'cancel'"/>
            </tree>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- Request Form View -->
    <!-- ============================================ -->
    <record id="spare_request_view_form" model="ir.ui.view">
        <field name="name">spare.request.form</field>
        <field name="model">spare.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object"
                            string="ส่งขออนุมัติ" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" type="object"
                            string="อนุมัติ" class="btn-success"
                            invisible="state != 'submitted'"/>
                    <button name="action_reject" type="object"
                            string="ไม่อนุมัติ" class="btn-danger"
                            invisible="state != 'submitted'"/>
                    <button name="action_pick" type="object"
                            string="หยิบของ (Pick)" class="btn-primary"
                            invisible="state != 'approved'"/>
                    <button name="action_done" type="object"
                            string="เสร็จสิ้น" class="btn-success"
                            invisible="state != 'picking'"/>
                    <button name="action_cancel" type="object"
                            string="ยกเลิก"
                            invisible="state in ('done', 'cancel')"/>
                    <button name="action_draft" type="object"
                            string="กลับเป็นร่าง"
                            invisible="state not in ('cancel', 'rejected')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,picking,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="requester_id"
                                   widget="many2one_avatar_user"/>
                            <field name="department"/>
                            <field name="date_request"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group>
                            <field name="approver_id"
                                   widget="many2one_avatar_user"/>
                            <field name="date_approved"/>
                            <field name="date_done"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason" placeholder="ระบุเหตุผลการเบิก..."/>
                    </group>
                    <group invisible="state != 'rejected'">
                        <field name="reject_reason"
                               placeholder="เหตุผลที่ไม่อนุมัติ..."/>
                    </group>
                    <notebook>
                        <page string="รายการเบิก" name="lines">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence"
                                           widget="handle"/>
                                    <field name="part_id"/>
                                    <field name="category_id"/>
                                    <field name="qty_on_hand"/>
                                    <field name="qty_requested"/>
                                    <field name="qty_approved"/>
                                    <field name="src_location_id"/>
                                </tree>
                            </field>
                        </page>
                        <page string="หมายเหตุ" name="notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- Request Search View -->
    <!-- ============================================ -->
    <record id="spare_request_view_search" model="ir.ui.view">
        <field name="name">spare.request.search</field>
        <field name="model">spare.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="requester_id"/>
                <field name="department"/>
                <filter string="ร่าง" name="draft"
                        domain="[('state','=','draft')]"/>
                <filter string="รออนุมัติ" name="submitted"
                        domain="[('state','=','submitted')]"/>
                <filter string="อนุมัติแล้ว" name="approved"
                        domain="[('state','=','approved')]"/>
                <filter string="กำลังหยิบ" name="picking"
                        domain="[('state','=','picking')]"/>
                <filter string="เสร็จสิ้น" name="done"
                        domain="[('state','=','done')]"/>
                <separator/>
                <filter string="ด่วน" name="urgent"
                        domain="[('priority','in',('1','2'))]"/>
                <filter string="ของฉัน" name="my_requests"
                        domain="[('requester_id','=',uid)]"/>
                <group expand="0" string="จัดกลุ่มตาม">
                    <filter string="สถานะ" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="ผู้ขอเบิก" name="group_requester"
                            context="{'group_by': 'requester_id'}"/>
                    <filter string="แผนก" name="group_dept"
                            context="{'group_by': 'department'}"/>
                    <filter string="เดือน" name="group_month"
                            context="{'group_by': 'date_request:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- Request Action -->
    <!-- ============================================ -->
    <record id="spare_request_action" model="ir.actions.act_window">
        <field name="name">ใบขอเบิกอะไหล่</field>
        <field name="res_model">spare.request</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_state': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                สร้างใบขอเบิกอะไหล่ใบแรก
            </p>
            <p>สร้าง → ส่งขออนุมัติ → อนุมัติ → หยิบของ → เสร็จสิ้น</p>
        </field>
    </record>
</odoo>
